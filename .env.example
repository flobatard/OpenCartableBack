# Secrets et overrides locaux UNIQUEMENT.
# La config publique (CORS, hôtes, OIDC, ...) vit dans config/<APP_ENV>.yaml.
# Priorité : variables d'env > .env > config/<APP_ENV>.yaml.

# Environnement : development (défaut) ou production
APP_ENV=development

# SECRET — mot de passe Postgres (aussi lu par docker-compose pour le service db)
POSTGRES_PASSWORD=change-me

# Override optionnel : URL complète (ex. Postgres managé type Neon).
# Prend le pas sur les POSTGRES_* ; sslmode/channel_binding sont traduits pour asyncpg.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Overrides OIDC éventuels (sinon valeurs de config/<APP_ENV>.yaml)
# OIDC_ISSUER=https://votre-instance.zitadel.cloud
# OIDC_AUDIENCE=client-id-ou-project-id-de-l-api
